# Скопируйте в .env и задайте свои значения (файл .env в git не попадает).
# Для локальной разработки можно не создавать .env — в settings.py есть безопасные значения по умолчанию.

DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
ADMIN_REGISTRATION_CODE=change-me-before-production
