# Локальная разработка: скопируйте в .env
# Production (Docker): скопируйте на сервер как .env рядом с docker-compose.yml

# Обязательно смените перед деплоем
DJANGO_SECRET_KEY=change-me-to-a-long-random-string
ADMIN_REGISTRATION_CODE=change-me-before-production

# 0 — production, 1 — локальная отладка
DJANGO_DEBUG=0

# Домен (Caddy автоматически получит HTTPS-сертификат)
DOMAIN=medpalto.us.kg
ACME_EMAIL=your-email@example.com

# IP и домен (без http://), через запятую
DJANGO_ALLOWED_HOSTS=medpalto.us.kg,www.medpalto.us.kg,45.12.19.168

# Полные URL с https:// (Caddy раздаёт HTTPS)
DJANGO_CSRF_TRUSTED_ORIGINS=https://medpalto.us.kg,https://www.medpalto.us.kg

# Gunicorn (опционально)
GUNICORN_WORKERS=2
GUNICORN_TIMEOUT=60
