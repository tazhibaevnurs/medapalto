# Локальная разработка: скопируйте в .env
# Production (Docker): скопируйте на сервер как .env рядом с docker-compose.yml

# Обязательно смените перед деплоем
DJANGO_SECRET_KEY=change-me-to-a-long-random-string
ADMIN_REGISTRATION_CODE=change-me-before-production

# 0 — production, 1 — локальная отладка
DJANGO_DEBUG=0

# IP или домен (без http://), через запятую
DJANGO_ALLOWED_HOSTS=45.12.19.168,localhost,127.0.0.1

# Полные URL с http:// или https:// и портом (для IP:8000 — укажите :8000)
# Можно оставить пустым для HTTP без reverse-proxy
DJANGO_CSRF_TRUSTED_ORIGINS=http://45.12.19.168:8000,http://localhost:8000

# Порт на хосте (внутри контейнера всегда 8000)
APP_PORT=8000

# Gunicorn (опционально)
GUNICORN_WORKERS=2
GUNICORN_TIMEOUT=60
